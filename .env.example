# ------- Database -------
# Neon Postgres connection string (pooled preferred for runtime; direct for drizzle-kit)
DATABASE_URL=postgresql://user:pass@ep-example.neon.tech/witus_inbox?sslmode=require

# ------- NextAuth v4 -------
# Full URL where the inbox is served (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
# 32+ random bytes. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# SMTP connection string for NextAuth's EmailProvider (Mailgun SMTP)
# Format: smtp://USERNAME:PASSWORD@smtp.mailgun.org:587
EMAIL_SERVER=smtp://postmaster@mg.witus.online:YOUR_SMTP_PASSWORD@smtp.mailgun.org:587
EMAIL_FROM=WitUS Inbox <inbox@witus.online>

# Admin gate — only this email can sign in successfully
ADMIN_EMAIL=you@example.com

# ------- Mailgun (direct API, for reply composer) -------
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.witus.online
# Universal DR archive address that every product also emails
BVC_SUBMISSIONS_EMAIL=bvc.witus.submissions@witus.online

# ------- Ingest webhook sources -------
# JSON array of { slug, hmac_secret } — one per product that will POST /api/ingest.
# In production, rows live in the webhook_source table; this env var is a
# bootstrap seed for local dev / preview.
# Example:
# INGEST_SOURCES=[{"slug":"witus-online","hmac_secret":"change-me-32-bytes"}]
INGEST_SOURCES=

# ------- Mobile Text Alerts (SMS on priority=high) -------
MOBILE_TEXT_ALERTS_API_KEY=
# JSON array of E.164 phone numbers (e.g. ["+15551234567"])
MOBILE_TEXT_ALERTS_RECIPIENTS=
